# Solas Trace Environment Variables Configuration
# Copy this file to .env before starting the application

# Server configuration
PORT=8080
RUST_LOG=info

# Database connection URL
DATABASE_URL=sqlite://solas_trace.db

# LLM Providers Configuration (Required for Live Sandbox Replays & LLM-as-a-Judge evaluations)
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Frontend Configuration
VITE_API_URL=http://localhost:8080
