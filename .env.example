# =============================================================================
# Solas Trace — Environment Configuration
# =============================================================================
# Copy to .env and customize. This file is used by ALL services.
#
# ⚡ Quick Start:
#   cp .env.example .env
#   docker compose up -d
#   cargo run                    # Backend on :8000
#   cd ui && npm run dev         # Frontend on :3000

# ── PostgreSQL (Metadata) ────────────────────────────────────────────────────
PG_VERSION=17
PG_USER=solas
PG_PASSWORD=solas-dev-pass          # CHANGEME in production
PG_DB=solas_trace
PG_PORT=5434
DATABASE_URL=postgresql://solas:solas-dev-pass@localhost:5434/solas_trace

# ── ClickHouse (Trace Storage) ───────────────────────────────────────────────
CH_VERSION=25.2
CH_USER=solas
CH_PASSWORD=solas-ch-pass           # CHANGEME in production
CH_DB=solas
CH_HTTP_PORT=8124
CH_NATIVE_PORT=9001
CLICKHOUSE_URL=http://solas:solas-ch-pass@localhost:8124/solas

# ── Redis (Queues & Cache) ───────────────────────────────────────────────────
REDIS_PASSWORD=solas-redis-pass     # CHANGEME in production
REDIS_PORT=6380
REDIS_URL=redis://:solas-redis-pass@localhost:6380/0

# ── MinIO (S3 Artifact Storage) ──────────────────────────────────────────────
MINIO_USER=solas-minio
MINIO_PASSWORD=solas-minio-secret   # CHANGEME in production
MINIO_API_PORT=9092
MINIO_CONSOLE_PORT=9093
S3_ENDPOINT=http://localhost:9092
S3_ACCESS_KEY=solas-minio
S3_SECRET_KEY=solas-minio-secret
S3_BUCKET_TRACES=solas-traces
S3_BUCKET_ARTIFACTS=solas-artifacts
S3_REGION=us-east-1

# ── Prometheus & Grafana (Monitoring — Solas exclusive) ──────────────────────
PROMETHEUS_PORT=9094
GRAFANA_USER=admin
GRAFANA_PASSWORD=solas-grafana      # CHANGEME in production
GRAFANA_PORT=3001

# ── Solas Trace Backend (Rust Axum) ──────────────────────────────────────────
SOLAS_HOST=0.0.0.0
SOLAS_PORT=8000
SOLAS_LOG_LEVEL=info
SOLAS_CORS_ORIGINS=http://localhost:3000

# ── Solas Auth ───────────────────────────────────────────────────────────────
AUTH_SECRET=solas-auth-32char-secret-change-me-now!!    # CHANGEME — must be 32+ chars
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Solas Frontend (Next.js) ────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Solas Trace
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3001
NEXT_PUBLIC_MINIO_CONSOLE=http://localhost:9093

# ── AI Agent / LLM Keys ─────────────────────────────────────────────────────
# Required for AI Assistant and Detector evaluations.
# At least one provider key is needed for AI features.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# MISTRAL_API_KEY=...
# DEEPSEEK_API_KEY=...

# ── Detector Engine ──────────────────────────────────────────────────────────
DETECTOR_SAMPLE_RATE=25
DETECTOR_EVAL_TIMEOUT_MS=60000
DETECTOR_BATCH_SIZE=50
DETECTOR_POLL_INTERVAL_SECONDS=5

# ── Agent Sandbox ────────────────────────────────────────────────────────────
SANDBOX_PROVIDER=docker
# SANDBOX_PROVIDER=firecracker       # Production: microVM isolation

# ── Encryption (BYOK API Key Storage) ────────────────────────────────────────
# 64-char hex string for AES-256-GCM encryption of user-provided API keys.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2

# ── Integrations ─────────────────────────────────────────────────────────────
# GitHub App (for PR creation, code context in RCA)
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_CLIENT_ID=
# GITHUB_APP_CLIENT_SECRET=

# Slack (for detector alerts)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

# PagerDuty (Solas exclusive — incident escalation)
# PAGERDUTY_ROUTING_KEY=
# PAGERDUTY_SERVICE_ID=

# Discord (Solas exclusive — team notifications)
# DISCORD_WEBHOOK_URL=

# ── Webhooks (Solas exclusive) ───────────────────────────────────────────────
# Generic outbound webhook for trace events
# WEBHOOK_URL=
# WEBHOOK_SECRET=

# ── Performance Tuning ───────────────────────────────────────────────────────
# Max spans per trace before auto-archiving to MinIO
MAX_SPANS_PER_TRACE=10000
# Max concurrent trace ingestion workers
INGESTION_WORKERS=4
# Trace retention in ClickHouse (days)
TRACE_RETENTION_DAYS=90
# Rate limiting (requests/minute per API key)
RATE_LIMIT_INGESTION=1000
RATE_LIMIT_READ=200
